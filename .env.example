UERJ_LOGIN=sua_matricula
UERJ_PASSWORD=sua_senha

# Telegram (recomendado) — crie um bot em @BotFather e adicione ao grupo
TELEGRAM_BOT_TOKEN=123456789:ABCdef...
TELEGRAM_CHAT_ID=-100123456789

# Email (Gmail) — use uma "Senha de App" em myaccount.google.com/apppasswords
EMAIL_FROM=seu@gmail.com
EMAIL_PASS=xxxx xxxx xxxx xxxx
EMAIL_TO=destinatario@email.com

# WhatsApp via Evolution API (opcional, requer self-hosting)
# EVOLUTION_API_URL=http://localhost:8080
# EVOLUTION_API_KEY=sua_api_key
# EVOLUTION_INSTANCE=nome_da_instancia
# WHATSAPP_TARGET=5521999999999
